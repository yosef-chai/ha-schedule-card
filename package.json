{
  "name": "ha-schedule-card",
  "version": "0.1.0",
  "description": "A Lovelace custom card for Home Assistant that visualizes schedule.* entities as a 24-hour timeline with daily/weekly and full/compact views.",
  "private": true,
  "type": "module",
  "main": "dist/ha-schedule-card.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "lint": "eslint src --ext .ts --max-warnings=0",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check": "npm run lint && npm run format:check && npm run check:i18n && npm run test",
    "prebuild": "npm run check"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "schedule",
    "hacs",
    "lit"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "lit": "^3.2.1",
    "custom-card-helpers": "^1.9.0",
    "home-assistant-js-websocket": "^9.4.0"
  },
  "devDependencies": {
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-lit": "^1.15.0",
    "prettier": "^3.3.3",
    "rollup": "^4.24.4",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
